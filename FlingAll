LocalPlayer.CharacterAdded:Connect(function()
    lastSafePos = nil
    currentTarget = nil
    isSwitching = false
end)

RunService.RenderStepped:Connect(function(dt)
    if espOn then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = p.Character.HumanoidRootPart
                if not hrp:FindFirstChild("ESPGui") then
                    local bg = Instance.new("BillboardGui", hrp); bg.Name = "ESPGui"; bg.Size = UDim2.new(0, 100, 0, 50); bg.AlwaysOnTop = true; bg.ExtentsOffset = Vector3.new(0, 3, 0)
                    local tl = Instance.new("TextLabel", bg); tl.Name = "Tag"; tl.Size = UDim2.new(1, 0, 1, 0); tl.BackgroundTransparency = 1; tl.TextColor3 = Color3.new(0, 1, 0.5); tl.Font = Enum.Font.SourceSansBold; tl.TextSize = 14
                end
                hrp.ESPGui.Tag.Text = p.DisplayName.."\n["..math.floor((hrp.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude).."m]"
            end
        end
    end
    PlayerStats.Text = "PLRS: "..#Players:GetPlayers(); PingStats.Text = "PING: "..math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()); FpsStats.Text = "FPS: "..math.floor(1/dt)
end)

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if antiOn and not agresifOn and not isSwitching then
        if lastSafePos then
            local moveDist = (hrp.Position - lastSafePos).Magnitude
            if moveDist > 20 then
                hrp.CFrame = CFrame.new(lastSafePos)
            else
                lastSafePos = hrp.Position
            end
        else
            lastSafePos = hrp.Position
        end
    end

    if agresifOn then 
        hrp.Velocity = Vector3.new(4000, 4000, 4000)
        hrp.RotVelocity = Vector3.new(4000, 4000, 4000)
    else
        local v = hrp.Velocity; hrp.Velocity = v * 10000 + Vector3.new(0, 10000, 0); RunService.RenderStepped:Wait(); hrp.Velocity = v 
    end
end)

local TPProxy = Instance.new("Part", workspace); TPProxy.Anchored = true; TPProxy.Transparency = 1; TPProxy.CanCollide = false; TPProxy.Size = Vector3.new(0.01, 0.01, 0.01)
RunService.Heartbeat:Connect(function()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp or isLanding then return end
    if autoTPOn then
        local inp = TargetBox.Text:upper()
        if inp == "ALL" or inp == "" then
            local list = {}
            for _,p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then table.insert(list, p) end end
            if not currentTarget or tick() - lastSwitch >= 3 then 
                if #list > 0 then 
                    isSwitching = true; allIndex = allIndex % #list + 1; currentTarget = list[allIndex]; lastSwitch = tick(); task.wait(0.1); isSwitching = false
                end 
            end
        else
            local found = nil
            for _,p in pairs(Players:GetPlayers()) do if p.Name:lower():find(inp:lower()) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then found = p break end end
            if found ~= currentTarget then isSwitching = true; currentTarget = found; task.wait(0.1); isSwitching = false end
        end
        if currentTarget and currentTarget.Character and currentTarget.Character:FindFirstChild("HumanoidRootPart") then
            local th = currentTarget.Character.HumanoidRootPart
            TPProxy.CFrame = th.CFrame; Camera.CameraSubject = TPProxy
            hrp.CFrame = rotationOn and th.CFrame * CFrame.Angles(math.rad(math.random(-180,180)), math.rad(math.random(-180,180)), math.rad(math.random(-180,180))) or th.CFrame
        end
    end
end)

AutoTPBtn.MouseButton1Click:Connect(function() autoTPOn = not autoTPOn; if not autoTPOn then isLanding = true; task.wait(0.1); Camera.CameraSubject = LocalPlayer.Character.Humanoid; isLanding = false end; UpdateUI() end)
RotationBtn.MouseButton1Click:Connect(function() rotationOn = not rotationOn; UpdateUI() end)
EspBtn.MouseButton1Click:Connect(function() espOn = not espOn; UpdateUI() end)
AntiFlingBtn.MouseButton1Click:Connect(function() antiOn = not antiOn; if not antiOn then lastSafePos = nil end; UpdateUI() end)
AgresifFlingBtn.MouseButton1Click:Connect(function() agresifOn = not agresifOn; UpdateUI() end)

UpdateUI()
