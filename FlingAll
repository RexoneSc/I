local isRolling, guiVisible = false, true
ToggleBtn.MouseButton1Click:Connect(function()
    if isRolling then return end; isRolling = true
    local targetSize = guiVisible and UDim2.new(1, 0, 0, 0) or originalSize
    local targetText = guiVisible and "Fling By Rexone  [ ∨ ]" or "Fling By Rexone  [ ∧ ]"
    local tween = TweenService:Create(Frame, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = targetSize})
